# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key-here"

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Path to the downloaded service account JSON file for Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH="path/to/firebase-service-account.json"

# ─── Match Schedule ───────────────────────────────────────────────────────────
# ISO-8601 UTC datetime of match kick-off.
# Used to compute dynamic match phase (pre-match / live / post-match).
# Example: MATCH_START_UTC="2026-06-11T20:00:00Z"
MATCH_START_UTC=""

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production: Add your Vercel deployment URL here.
# Example: ALLOWED_ORIGINS="http://localhost:3000,https://your-app.vercel.app"
ALLOWED_ORIGINS="http://localhost:3000"
